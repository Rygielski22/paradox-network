{
  "namespace": "serverform",

  "main_screen_content": {
    "modifications": [
      {
        "array_name": "controls",
        "operation": "insert_back",
        "value": [
          {
            "meteor_form_factory": {
              "type": "panel",
              "factory": {
                "name": "server_form_factory",
                "control_ids": {
                  "long_form": "@serverform.meteor_long_form"
                }
              }
            }
          }
        ]
      }
    ]
  },

  "long_form": {
    "modifications": [
      {
        "array_name": "bindings",
        "operation": "insert_back",
        "value": [
          { "binding_name": "#title_text" },
          {
            "binding_type": "view",
            "source_property_name": "((#title_text - 'meteor:') = #title_text)",
            "target_property_name": "#visible"
          }
        ]
      }
    ]
  },

  "meteor_button": {
    "type": "button",
    "size": ["100%", 30],
    "$pressed_button_name": "button.form_button_click",
    "default_control": "default",
    "hover_control": "hover",
    "locked_control": "default",
    "controls": [
      {
        "default": {
          "type": "image",
          "texture": "textures/ui/Black",
          "color": [0.10, 0.06, 0.18, 0.97],
          "size": ["100%", "100%"],
          "controls": [
            {
              "stripe": {
                "type": "image",
                "texture": "textures/ui/White",
                "color": [0.42, 0.18, 0.78, 1],
                "size": [2, "86%"],
                "anchor_from": "left_middle",
                "anchor_to": "left_middle",
                "offset": [4, 0],
                "layer": 2
              }
            },
            {
              "txt": {
                "type": "label",
                "text": "#form_button_text",
                "color": [0.92, 0.88, 0.98, 1],
                "layer": 2,
                "anchor_from": "left_middle",
                "anchor_to": "left_middle",
                "offset": [12, 0],
                "bindings": [{ "binding_name": "#form_button_text" }]
              }
            }
          ]
        }
      },
      {
        "hover": {
          "type": "image",
          "texture": "textures/ui/White",
          "color": [0.30, 0.12, 0.55, 0.99],
          "size": ["100%", "100%"],
          "controls": [
            {
              "stripe": {
                "type": "image",
                "texture": "textures/ui/White",
                "color": [0.78, 0.32, 0.95, 1],
                "size": [3, "92%"],
                "anchor_from": "left_middle",
                "anchor_to": "left_middle",
                "offset": [4, 0],
                "layer": 2
              }
            },
            {
              "chev": {
                "type": "label",
                "text": "§f>",
                "color": [1, 1, 1, 1],
                "layer": 2,
                "anchor_from": "right_middle",
                "anchor_to": "right_middle",
                "offset": [-8, 0]
              }
            },
            {
              "txt": {
                "type": "label",
                "text": "#form_button_text",
                "color": [1, 1, 1, 1],
                "layer": 2,
                "anchor_from": "left_middle",
                "anchor_to": "left_middle",
                "offset": [12, 0],
                "bindings": [{ "binding_name": "#form_button_text" }]
              }
            }
          ]
        }
      }
    ],
    "bindings": [
      { "binding_type": "collection_details", "binding_collection_name": "form_buttons" }
    ]
  },

  "meteor_button_row": {
    "type": "panel",
    "size": ["100%", 33],
    "controls": [{ "b@serverform.meteor_button": {} }]
  },

  "meteor_buttons_panel": {
    "type": "stack_panel",
    "orientation": "vertical",
    "size": ["100%", "100%c"],
    "collection_name": "form_buttons",
    "factory": { "name": "buttons", "control_name": "serverform.meteor_button_row" },
    "bindings": [
      { "binding_name": "#form_button_length", "binding_name_override": "#collection_length" }
    ]
  },

  "meteor_long_form": {
    "type": "panel",
    "size": [310, "100%c"],
    "bindings": [
      { "binding_name": "#title_text" },
      {
        "binding_type": "view",
        "source_property_name": "(not ((#title_text - 'meteor:') = #title_text))",
        "target_property_name": "#visible"
      }
    ],
    "controls": [
      {
        "body": {
          "type": "image",
          "texture": "textures/ui/Black",
          "color": [0.06, 0.04, 0.10, 0.96],
          "size": ["100%", "100%"],
          "layer": 0
        }
      },
      {
        "edge": {
          "type": "image",
          "texture": "textures/ui/White",
          "color": [0.42, 0.18, 0.78, 1],
          "alpha": 0.25,
          "size": ["100%", "100%"],
          "layer": 0
        }
      },
      {
        "stack": {
          "type": "stack_panel",
          "orientation": "vertical",
          "size": ["100%", "100%c"],
          "layer": 2,
          "controls": [
            {
              "header": {
                "type": "image",
                "texture": "textures/ui/Black",
                "color": [0.10, 0.06, 0.18, 0.99],
                "size": ["100%", 34],
                "controls": [
                  {
                    "title": {
                      "type": "label",
                      "text": "#processed_title",
                      "color": [0.88, 0.72, 0.98, 1],
                      "anchor_from": "left_middle",
                      "anchor_to": "left_middle",
                      "offset": [12, 0],
                      "font_scale_factor": 1.35,
                      "shadow": true,
                      "layer": 3,
                      "bindings": [
                        { "binding_name": "#title_text" },
                        {
                          "binding_type": "view",
                          "source_property_name": "(#title_text - 'meteor:')",
                          "target_property_name": "#processed_title"
                        }
                      ]
                    }
                  },
                  {
                    "rule": {
                      "type": "image",
                      "texture": "textures/ui/White",
                      "color": [0.42, 0.18, 0.78, 1],
                      "size": ["100%", 1],
                      "anchor_from": "bottom_middle",
                      "anchor_to": "bottom_middle",
                      "layer": 3
                    }
                  }
                ]
              }
            },
            { "gap": { "type": "panel", "size": ["100%", 6] } },
            { "buttons@serverform.meteor_buttons_panel": {} },
            { "gap2": { "type": "panel", "size": ["100%", 8] } }
          ]
        }
      }
    ]
  }
}
